<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="SteamWatch.App.MainPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="using:SteamWatch.App"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    Background="{ThemeResource ApplicationPageBackgroundThemeBrush}"
    mc:Ignorable="d">

    <NavigationView
        x:Name="RootNavigation"
        IsBackButtonVisible="Collapsed"
        IsSettingsVisible="True"
        PaneDisplayMode="LeftCompact"
        SelectionChanged="RootNavigation_SelectionChanged">
        <NavigationView.MenuItems>
            <NavigationViewItem
                Content="游戏"
                Icon="Play"
                Tag="Games" />
            <NavigationViewItem
                Content="统计"
                Icon="Calendar"
                Tag="Statistics" />
            <NavigationViewItem
                Content="日志"
                Icon="Document"
                Tag="ActivityLog" />
        </NavigationView.MenuItems>

        <Grid Padding="24">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="16" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <StackPanel Spacing="4">
                <TextBlock
                    x:Name="PageTitle"
                    FontSize="28"
                    FontWeight="SemiBold"
                    Text="游戏" />
                <TextBlock
                    x:Name="PageSubtitle"
                    Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                    Text="今日 0 分钟 / 本周 0 分钟" />
            </StackPanel>

            <Grid
                x:Name="GamesView"
                Grid.Row="2"
                ColumnSpacing="16"
                RowSpacing="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="2*" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <CommandBar
                    Grid.ColumnSpan="2"
                    DefaultLabelPosition="Right">
                    <AppBarButton
                        x:Name="RefreshButton"
                        Icon="Refresh"
                        Label="刷新"
                        Click="RefreshButton_Click" />
                    <AppBarButton
                        Icon="Clock"
                        Label="设置限额" />
                    <AppBarButton
                        Icon="Stop"
                        Label="强退策略" />
                </CommandBar>

                <ListView
                    Grid.Row="1"
                    ItemsSource="{x:Bind GameRows}">
                    <ListView.ItemTemplate>
                        <DataTemplate x:DataType="local:GameRowViewModel">
                            <Grid
                                Padding="0,12"
                                ColumnSpacing="12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock
                                        FontSize="16"
                                        FontWeight="SemiBold"
                                        Text="{x:Bind Name}" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind AppIdText}" />
                                    <TextBlock
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind Status}" />
                                </StackPanel>
                                <StackPanel
                                    Grid.Column="1"
                                    HorizontalAlignment="Right">
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        Text="{x:Bind TodayText}" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind WeekText}" />
                                    <TextBlock
                                        HorizontalAlignment="Right"
                                        Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                                        Text="{x:Bind SteamPlaytimeText}" />
                                </StackPanel>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>

                <StackPanel
                    Grid.Row="1"
                    Grid.Column="1"
                    Spacing="16">
                    <InfoBar
                        IsOpen="True"
                        Message="{x:Bind StatusMessage, Mode=OneWay}"
                        Severity="Informational"
                        Title="Steam 状态" />
                    <StackPanel Spacing="8">
                        <TextBlock
                            FontSize="18"
                            FontWeight="SemiBold"
                            Text="限额概览" />
                        <ProgressBar
                            Maximum="100"
                            Value="0" />
                        <TextBlock
                            Foreground="{ThemeResource TextFillColorSecondaryBrush}"
                            Text="{x:Bind GameCountText, Mode=OneWay}" />
                    </StackPanel>
                </StackPanel>
            </Grid>

            <Grid
                x:Name="SettingsView"
                Grid.Row="2"
                RowSpacing="16"
                Visibility="Collapsed">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <ToggleSwitch
                    Header="开机自启"
                    OffContent="关闭"
                    OnContent="开启" />
                <ComboBox
                    Grid.Row="1"
                    Header="关闭窗口时"
                    SelectedIndex="0">
                    <ComboBoxItem Content="最小化到托盘" />
                    <ComboBoxItem Content="退出应用" />
                </ComboBox>
                <ToggleSwitch
                    Grid.Row="2"
                    Header="默认启用声音提醒"
                    IsOn="True"
                    OffContent="关闭"
                    OnContent="开启" />
            </Grid>
        </Grid>
    </NavigationView>
</Page>
